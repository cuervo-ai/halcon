---
import { t, getAlternatePath } from '../../i18n/translations';
import type { Lang } from '../../i18n/translations';

interface Props {
  lang:        Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const altPath  = getAlternatePath(lang, currentPath);
const prefix   = lang === 'es' ? '/es' : '';

// Detección de página activa
const isHome     = currentPath === '/' || currentPath === '/es' || currentPath === '/es/';
const isDocs     = currentPath.includes('/docs');
const isDownload = currentPath.includes('/download');

// Para links de anchor: si ya estamos en home, solo #hash; si no, navegamos a home + hash
const homeHref = isHome ? '' : prefix + '/';

const navLinks = [
  {
    href:     homeHref + '#providers',
    label:    t(lang, 'nav.providers'),
    isAnchor: true,
    active:   false,
  },
  {
    href:     homeHref + '#features',
    label:    t(lang, 'nav.features'),
    isAnchor: true,
    active:   false,
  },
  {
    href:     prefix + '/docs',
    label:    t(lang, 'nav.docs'),
    isAnchor: false,
    active:   isDocs,
    prefetch: true,
  },
];
---

<header id="site-header" class="fixed top-0 z-50 w-full transition-all duration-300 navbar-glass">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={prefix + '/'}
         class="flex items-center gap-3 group shrink-0"
         aria-label="Halcón CLI"
         data-astro-prefetch>
        <div class="relative flex-shrink-0">
          <div class="absolute inset-0 rounded-lg blur-md opacity-0 group-hover:opacity-60 transition-opacity duration-500"
               style="background: radial-gradient(circle, rgba(232,82,0,0.8) 0%, transparent 70%);"></div>
          <img src="/halcon-logo.png" alt="Halcón"
               class="relative h-9 w-9 object-contain transition-transform duration-300 group-hover:scale-105"
               style="filter: drop-shadow(0 0 8px rgba(232,82,0,0.4));" />
        </div>
        <div class="flex flex-col leading-none">
          <span class="font-display font-bold text-xl tracking-widest uppercase gradient-text-brand">HALCÓN</span>
          <span class="font-mono tracking-wider" style="color: var(--c-t4); font-size: 0.58rem;">CLI · v0.2.0</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center" aria-label="Main navigation">

        <!-- Links principales -->
        <div class="flex items-center gap-0.5 mr-3">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={['nav-link', 'relative', 'px-3.5', 'py-2', 'text-sm', 'font-medium', 'rounded-lg', 'transition-all', 'duration-150', link.active && 'nav-link--active']}
              data-astro-prefetch={link.prefetch ? 'hover' : undefined}
              aria-current={link.active ? 'page' : undefined}
            >
              {link.label}
              <!-- indicador inferior -->
              <span class:list={['nav-indicator', 'absolute', 'bottom-0.5', 'left-3', 'right-3', 'h-px', 'rounded-full', 'transition-all', 'duration-150', link.active ? 'nav-indicator--active' : 'nav-indicator--idle']}></span>
            </a>
          ))}
        </div>

        <!-- Separador vertical -->
        <div class="h-5 w-px mr-3" style="background: var(--c-b);"></div>

        <!-- Language switcher -->
        <a href={altPath}
           title={t(lang, 'nav.lang_label')}
           class="flex items-center gap-1.5 px-2.5 py-1.5 text-xs font-mono rounded-lg transition-all duration-150 mr-2"
           style="color: var(--c-t3); border: 1px solid var(--c-b);"
           id="lang-btn">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          <span>{t(lang, 'nav.lang')}</span>
        </a>

        <!-- Download CTA -->
        <a href={prefix + '/download'}
           class="btn-primary"
           style="padding: 0.45rem 1.1rem; font-size: 0.8rem; gap: 0.4rem;"
           data-astro-prefetch="hover">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          {t(lang, 'nav.download')}
        </a>
      </nav>

      <!-- Mobile: lang + burger en el mismo contenedor -->
      <div class="md:hidden flex items-center gap-2">
        <a href={altPath}
           class="flex items-center gap-1 px-2 py-1.5 text-xs font-mono rounded-md transition-colors"
           style="color: var(--c-t3); border: 1px solid var(--c-b);">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          {t(lang, 'nav.lang')}
        </a>

        <button id="mobile-menu-btn"
                class="p-2 rounded-lg transition-all duration-150"
                style="color: var(--c-t2); border: 1px solid var(--c-b);"
                aria-label="Open menu" aria-expanded="false">
          <svg id="icon-open"  class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu — animated height -->
  <div id="mobile-menu"
       class="md:hidden overflow-hidden border-t"
       style="max-height: 0; opacity: 0; transition: max-height 0.25s cubic-bezier(0.4,0,0.2,1), opacity 0.2s ease; border-color: var(--c-b); background: rgba(7,4,1,0.97);">
    <div class="px-4 py-3 space-y-0.5">
      {navLinks.map(link => (
        <a href={link.href}
           class:list={['mobile-nav-link', 'flex', 'items-center', 'justify-between', 'px-4', 'py-3', 'rounded-xl', 'text-sm', 'font-medium', 'transition-all', 'duration-150', link.active && 'mobile-nav-link--active']}
           data-astro-prefetch={link.prefetch ? 'hover' : undefined}
           aria-current={link.active ? 'page' : undefined}>
          {link.label}
          {link.active && (
            <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background: var(--c-p);"></span>
          )}
        </a>
      ))}

      <div class="pt-2 pb-1">
        <a href={prefix + '/download'}
           class="btn-primary w-full justify-center"
           style="padding: 0.75rem; font-size: 0.875rem;"
           data-astro-prefetch="hover">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          {t(lang, 'nav.download')} Halcón CLI
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  /* ── Nav links desktop ───────────────────────────────── */
  .nav-link {
    color: var(--c-t2);
  }
  .nav-link:hover {
    color: var(--c-t1);
    background: rgba(200, 80, 0, 0.08);
  }
  .nav-link--active {
    color: var(--c-p) !important;
    background: rgba(232, 82, 0, 0.10);
  }

  /* Indicador inferior */
  .nav-indicator--idle {
    background: transparent;
    transform: scaleX(0);
    transform-origin: left;
  }
  .nav-link:hover .nav-indicator--idle {
    background: linear-gradient(90deg, var(--c-p), var(--c-gold));
    transform: scaleX(1);
  }
  .nav-indicator--active {
    background: linear-gradient(90deg, var(--c-p), var(--c-gold));
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ── Lang btn hover ──────────────────────────────────── */
  #lang-btn:hover {
    color: var(--c-gold);
    border-color: var(--c-b-gold);
    background: var(--c-gold-bg);
  }

  /* ── Mobile nav links ────────────────────────────────── */
  .mobile-nav-link {
    color: var(--c-t2);
  }
  .mobile-nav-link:hover {
    color: var(--c-t1);
    background: rgba(200, 80, 0, 0.08);
  }
  .mobile-nav-link--active {
    color: var(--c-p) !important;
    background: rgba(232, 82, 0, 0.10);
  }

  /* ── View Transition: el main hace fade ─────────────── */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 150ms;
  }
</style>

<script>
  // ─── Scroll glass effect ───────────────────────────────
  function initScrollGlass() {
    const header = document.getElementById('site-header');
    if (!header) return;
    const handler = () => {
      if (window.scrollY > 20) {
        header.classList.remove('navbar-glass');
        header.classList.add('navbar-glass-scrolled');
      } else {
        header.classList.remove('navbar-glass-scrolled');
        header.classList.add('navbar-glass');
      }
    };
    window.removeEventListener('scroll', handler);
    window.addEventListener('scroll', handler, { passive: true });
    handler();
  }

  // ─── Mobile menu ──────────────────────────────────────
  function initMobileMenu() {
    const btn    = document.getElementById('mobile-menu-btn');
    const menu   = document.getElementById('mobile-menu');
    const iOpen  = document.getElementById('icon-open');
    const iClose = document.getElementById('icon-close');
    if (!btn || !menu) return;

    let isOpen = false;

    function open() {
      isOpen = true;
      menu.style.maxHeight = menu.scrollHeight + 'px';
      menu.style.opacity   = '1';
      iOpen?.classList.add('hidden');
      iClose?.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      btn.style.borderColor = 'rgba(232,82,0,0.35)';
    }

    function close() {
      isOpen = false;
      menu.style.maxHeight = '0';
      menu.style.opacity   = '0';
      iOpen?.classList.remove('hidden');
      iClose?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      btn.style.borderColor = '';
    }

    btn.addEventListener('click', () => isOpen ? close() : open());
    menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => setTimeout(close, 80));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    });
  }

  // ─── MOMOTO: colores OKLCH en tiempo real ──────────────
  async function initHeaderMomoto() {
    try {
      const {
        batchDeriveColors, shiftColor, deriveFullStateColors,
        checkContrast, isAccessible, hexToOklch,
        derive_token_for_state, get_state_metadata, combine_states,
        BRAND_FIRE, BRAND_EMBER, BRAND_GOLD, BRAND_TEXT1, BRAND_BG,
      } = await import('../../lib/momoto/index');

      // 1) Batch derive fire + gold + ember en un solo call WASM
      const [fireStates, goldStates, emberStates] = await batchDeriveColors([
        BRAND_FIRE, BRAND_GOLD, BRAND_EMBER,
      ]);

      // 2) Logo glow — shift fire hacia más saturado
      const logoGlowColor = await shiftColor(BRAND_FIRE, { lightness: 0.08, chroma: 0.04 });
      const logoEl = document.querySelector<HTMLElement>('#site-header .group .absolute');
      if (logoEl) {
        logoEl.style.background = `radial-gradient(circle, ${logoGlowColor}cc 0%, transparent 70%)`;
      }

      // 3) Nav indicators (underline activo) — gradient fire→gold desde momoto
      const indicatorStyle = `linear-gradient(90deg, ${fireStates.idle}, ${goldStates.idle})`;
      document.querySelectorAll<HTMLElement>('.nav-indicator--active').forEach(el => {
        el.style.background = indicatorStyle;
      });
      // Hover via CSS custom property
      document.documentElement.style.setProperty('--m-nav-indicator', indicatorStyle);

      // 4) CTA Download button — full state colors desde momoto
      const ctaStates = await deriveFullStateColors(BRAND_FIRE.l, BRAND_FIRE.c, BRAND_FIRE.h);
      document.querySelectorAll<HTMLElement>('a.btn-primary').forEach(btn => {
        btn.style.background = `linear-gradient(135deg, ${ctaStates.idle} 0%, ${emberStates.idle} 100%)`;
        btn.style.boxShadow  = `0 4px 20px ${ctaStates.idle}60, inset 0 1px 0 rgba(255,255,255,0.10)`;
        btn.addEventListener('mouseenter', () => {
          btn.style.background  = `linear-gradient(135deg, ${ctaStates.hover} 0%, ${ctaStates.idle} 100%)`;
          btn.style.boxShadow   = `0 8px 36px ${ctaStates.hover}88, 0 2px 8px rgba(0,0,0,0.4)`;
        });
        btn.addEventListener('mouseleave', () => {
          btn.style.background  = `linear-gradient(135deg, ${ctaStates.idle} 0%, ${emberStates.idle} 100%)`;
          btn.style.boxShadow   = `0 4px 20px ${ctaStates.idle}60, inset 0 1px 0 rgba(255,255,255,0.10)`;
        });
      });

      // 5) Lang button hover — colores gold desde momoto
      const langBtn = document.getElementById('lang-btn') as HTMLElement | null;
      if (langBtn) {
        langBtn.addEventListener('mouseenter', () => {
          langBtn.style.color       = goldStates.idle;
          langBtn.style.borderColor = `${goldStates.idle}44`;
          langBtn.style.background  = `${goldStates.idle}12`;
        });
        langBtn.addEventListener('mouseleave', () => {
          langBtn.style.color       = '';
          langBtn.style.borderColor = '';
          langBtn.style.background  = '';
        });
      }

      // 6) Nav links active color desde momoto
      document.querySelectorAll<HTMLElement>('.nav-link--active').forEach(el => {
        el.style.color      = fireStates.idle;
        el.style.background = `${fireStates.idle}18`;
      });

      // 7) Mobile nav active
      document.querySelectorAll<HTMLElement>('.mobile-nav-link--active').forEach(el => {
        el.style.color      = fireStates.idle;
        el.style.background = `${fireStates.idle}15`;
      });

      // 8) Navbar scrolled border desde momoto
      const navBorderColor = await shiftColor(BRAND_FIRE, { lightness: -0.10, chroma: -0.05 });
      const styleEl = document.createElement('style');
      styleEl.id = 'momoto-header-styles';
      document.getElementById('momoto-header-styles')?.remove();
      styleEl.textContent = `
        .navbar-glass-scrolled {
          border-bottom-color: ${navBorderColor}38 !important;
          box-shadow: 0 4px 32px ${navBorderColor}20, 0 1px 0 ${goldStates.idle}0d !important;
        }
        .nav-link:hover .nav-indicator--idle {
          background: ${indicatorStyle} !important;
        }
        .nav-link:hover {
          background: ${fireStates.idle}0f !important;
        }
      `;
      document.head.appendChild(styleEl);

      // 9) derive_token_for_state — estado idle del fuego para logo
      const logoToken = await derive_token_for_state(BRAND_FIRE, 0 /* UIState.Idle */);

      // 10) get_state_metadata — metadata del estado idle
      const idleMeta = await get_state_metadata(0 /* UIState.Idle */);

      // 11) checkContrast — texto sobre navbar
      const contrast = await checkContrast(BRAND_TEXT1, BRAND_BG);

      // 12) isAccessible — gate WCAG AA
      const ok = await isAccessible(BRAND_TEXT1, BRAND_BG);

    } catch (_e) {
      // CSS estático como fallback — nada se rompe
    }
  }

  // ─── Boot ─────────────────────────────────────────────
  function initHeader() {
    initScrollGlass();
    initMobileMenu();
    initHeaderMomoto();
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
