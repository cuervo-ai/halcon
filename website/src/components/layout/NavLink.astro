---
interface Props {
  href: string;
  children: string;
}
const { href, children } = Astro.props;
---

<a
  href={href}
  class="text-sm font-medium text-gray-300 hover:text-white transition-colors relative group"
>
  {children}
  <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-purple-500 group-hover:w-full transition-all duration-300"></span>
</a>