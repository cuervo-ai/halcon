}
.mat-contrast-pass { background: rgba(34,197,94,0.12); color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
.mat-contrast-fail { background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }

/* ── Notes section ───────────────────────────────────────────────────────── */
.mat-notes { margin-top: 1rem; }
