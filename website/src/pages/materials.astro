}
.mat-note-card ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.mat-note-card li {
  font-size: 0.75rem;
  color: var(--c-t3);
  padding-left: 0.75rem;
  position: relative;
  line-height: 1.5;
}
.mat-note-card li::before {
  content: '—';
  position: absolute;
  left: 0;
