/* ── Properties table ────────────────────────────────────────────────────── */
.mat-props {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  margin: 0.75rem 1rem 0;
  border: 1px solid rgba(200,80,0,0.06);
