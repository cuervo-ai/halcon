/* ── Inspector section ───────────────────────────────────────────────────── */
.mat-inspector {
  border-radius: 1.25rem;
  padding: 1.75rem;
  margin-bottom: 2.5rem;
  border: 1px solid rgba(200,80,0,0.12);
}

.mat-inspector-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}
.mat-inspector-title {
  font-family: var(--font-display);
