/* ── Live Momoto card glow (CSS vars set by JS batchDeriveFast) ──────────── */
.mat-card {
  --m-glow: rgba(232,82,0,0.0);
  --m-edge: rgba(232,82,0,0.12);
  transition: border-color 0.25s ease, box-shadow 0.8s ease;
}

/* ── Reduced motion ──────────────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .mat-hero-title { animation: none; }
  .mat-scroll-hint { animation: none; }
  .mat-card { transition: none; }
}
</style>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<script>
  /**
   * Material Lab — SOTA Bootstrap  (IT1 + IT2 + IT3)
   * ──────────────────────────────────────────────────
   * IT1: CSS/WebGL correctness + error boundaries
   * IT2: Physics→Momoto OKLCH bridge (live heat drives color derivation)
   *      getMaterialPalette() → live card glows via CSS box-shadow
   *      batchDeriveFast() with simulation-shifted OKLCH base colors
   * IT3: WASM init + ramp timing display, WCAG live validation,
   *      engineCacheSize() growth tracking
   */

  // ── Dynamic import helper: bypasses Astro/Vite public-dir guard in dev ────
  // new Function trick makes the URL opaque to static analysis.
  function dynImport(url: string): Promise<any> {
    return new Function('u', 'return import(u)')(url) as Promise<any>;
  }

  // ── Shared physics state: populated by each simulation's onStats ──────────
  const simStats: Record<string, { fps: number; heatLevel: number }> = {
    ignis:  { fps: 60, heatLevel: 0.60 },   // IGNIS always hot
    aqua:   { fps: 60, heatLevel: 0.50 },
    velum:  { fps: 60, heatLevel: 0.30 },
    ferrum: { fps: 60, heatLevel: 0.05 },
  };

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  async function bootMaterials() {
    // ── 1. Initialize Momoto WASM + time it ────────────────────────────────
    const t0 = performance.now();
    const {
      initMomoto, buildFireRamp, batchDeriveFast, getMaterialPalette,
      checkContrast, engineCacheSize,
      BRAND_FIRE, BRAND_GOLD, BRAND_EMBER, BRAND_SPARK, BRAND_BG, BRAND_TEXT1,
    } = await import('../lib/momoto/index');
    await initMomoto();
    const initMs = (performance.now() - t0).toFixed(1);

    // ── 2. Build 256-step OKLCH fire ramp + time it ───────────────────────
    const t1 = performance.now();
    const ramp = await buildFireRamp(256);
    const rampMs = (performance.now() - t1).toFixed(1);

    // Update badge
    const label = document.getElementById('mat-wasm-label');
    const dot   = document.querySelector<HTMLElement>('.mat-wasm-dot');
    if (label) label.textContent = `WASM ${initMs}ms · ramp ${rampMs}ms · ${ramp.length} stops`;
    dot?.classList.add('ready');

    // ── 3. Apply initial Momoto material palettes to cards ─────────────────
    // getMaterialPalette() → glow / edge tokens → CSS vars + box-shadow
    const cardDefs = [
      { id: 'card-ignis',  base: BRAND_FIRE  },
      { id: 'card-aqua',   base: BRAND_GOLD  },
      { id: 'card-velum',  base: BRAND_EMBER },
      { id: 'card-ferrum', base: BRAND_SPARK },
    ] as const;

    await Promise.all(cardDefs.map(async ({ id, base }) => {
      const pal = await getMaterialPalette(base);
      const el  = document.getElementById(id) as HTMLElement | null;
      if (el) {
        el.style.setProperty('--m-glow', pal.glow);
        el.style.setProperty('--m-edge', pal.edge);
      }
    }));

    // ── 4. Boot simulations (skip if user prefers-reduced-motion) ──────────
    if (!prefersReduced) {
      await Promise.allSettled([
        bootHeroFire(ramp),
        bootIgnis(ramp),
        bootAqua(ramp),
        bootVelum(ramp),
        bootFerrum(ramp),
      ]);
    }

    // ── 5. Start live Momoto inspector ─────────────────────────────────────
    startInspector(ramp, {
      batchDeriveFast, getMaterialPalette, checkContrast, engineCacheSize,
      BRAND_FIRE, BRAND_GOLD, BRAND_EMBER, BRAND_SPARK, BRAND_BG, BRAND_TEXT1,
    });
  }

  // ── Hero background (IGNIS WebGL, full-bleed) — IT1: WebGL fallback ────────
  async function bootHeroFire(ramp: string[]) {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    try {
      const { IgnisSimulation } = await dynImport('/sim/fire-sim.js');
      const sim = new IgnisSimulation(canvas);
      if (!sim.init()) throw new Error('WebGL context failed');
      sim.setColorRamp(ramp);
    } catch {
      // IT1: WebGL fallback — static radial gradient matching brand palette
      const hero = document.getElementById('mat-hero') as HTMLElement | null;
      if (hero) {
        hero.style.background = [
          'radial-gradient(ellipse 80% 60% at 50% 90%, rgba(196,20,0,0.40) 0%, rgba(7,4,1,0) 65%)',
          'radial-gradient(ellipse 40% 30% at 30% 70%, rgba(232,82,0,0.20) 0%, rgba(7,4,1,0) 55%)',
          'linear-gradient(180deg, #070401 0%, #0e0401 100%)',
        ].join(', ');
      }
    }
  }

  function markLoaded(canvasId: string) {
    const wrap = document.getElementById(canvasId)?.parentElement;
    if (wrap) wrap.classList.add('sim-loaded');
  }

  // ── IGNIS card ────────────────────────────────────────────────────────────
  async function bootIgnis(ramp: string[]) {
    const canvas = document.getElementById('ignis-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    try {
      const { IgnisSimulation } = await dynImport('/sim/fire-sim.js');
      const sim = new IgnisSimulation(canvas);
      if (!sim.init()) return;
      sim.setColorRamp(ramp);
      markLoaded('ignis-canvas');
      const resEl = document.getElementById('ignis-res');
      if (resEl) {
        resEl.textContent = `${sim.simW}×${sim.simH}`;
        new ResizeObserver(() => { resEl.textContent = `${sim.simW}×${sim.simH}`; }).observe(canvas);
      }
      sim.onStats = ({ fps }: { fps: number }) => {
        const el = document.getElementById('ignis-fps');
        if (el) el.textContent = String(fps);
        simStats['ignis'].fps = fps;
      };
    } catch (e) { console.warn('[IGNIS] init failed:', e); }
  }

  // ── AQUA card ─────────────────────────────────────────────────────────────
  async function bootAqua(ramp: string[]) {
    const canvas = document.getElementById('aqua-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    try {
      const { AquaSimulation } = await dynImport('/sim/fluid-sim.js');
      const sim = new AquaSimulation(canvas);
      if (!sim.init()) return;
      sim.setColorRamp(ramp);
      markLoaded('aqua-canvas');
      const countEl = document.getElementById('aqua-count');
      if (countEl) countEl.textContent = String(sim.N);
      sim.onStats = ({ fps, avgTemp }: { fps: number; avgTemp: number }) => {
        const el = document.getElementById('aqua-fps');
        if (el) el.textContent = String(fps);
        simStats['aqua'].fps = fps;
        simStats['aqua'].heatLevel = avgTemp ?? 0.5;
      };
    } catch (e) { console.warn('[AQUA] init failed:', e); }
  }

  // ── VELUM card ────────────────────────────────────────────────────────────
  async function bootVelum(ramp: string[]) {
    const canvas = document.getElementById('velum-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    try {
      const { VelumSimulation } = await dynImport('/sim/cloth-sim.js');
      const sim = new VelumSimulation(canvas);
      if (!sim.init()) return;
      sim.setColorRamp(ramp);
      markLoaded('velum-canvas');
      const nodesEl = document.getElementById('velum-nodes');
      if (nodesEl) nodesEl.textContent = String(sim.COLS * sim.ROWS);
      sim.onStats = ({ fps, avgTemp }: { fps: number; avgTemp: number }) => {
        const el = document.getElementById('velum-fps');
        if (el) el.textContent = String(fps);
        simStats['velum'].fps = fps;
        simStats['velum'].heatLevel = avgTemp ?? 0.3;
      };
    } catch (e) { console.warn('[VELUM] init failed:', e); }
  }

  // ── FERRUM card ───────────────────────────────────────────────────────────
  async function bootFerrum(ramp: string[]) {
    const canvas = document.getElementById('ferrum-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    try {
      const { FerrumSimulation } = await dynImport('/sim/molten-sim.js');
      const sim = new FerrumSimulation(canvas);
      if (!sim.init()) return;
      sim.setColorRamp(ramp);
      markLoaded('ferrum-canvas');
      sim.onStats = ({ fps, moltFrac }: { fps: number; moltFrac: number }) => {
        const fpsEl  = document.getElementById('ferrum-fps');
        const meltEl = document.getElementById('ferrum-melt');
        if (fpsEl)  fpsEl.textContent  = String(fps);
        if (meltEl) meltEl.textContent = `${Math.round(moltFrac * 100)}%`;
        simStats['ferrum'].fps = fps;
        simStats['ferrum'].heatLevel = moltFrac;
      };
    } catch (e) { console.warn('[FERRUM] init failed:', e); }
  }

  // ── Momoto Live Inspector — IT2: physics heat drives OKLCH derivation ──────
  function startInspector(ramp: string[], api: {
    batchDeriveFast: Function; getMaterialPalette: Function; checkContrast: Function;
    engineCacheSize: Function;
    BRAND_FIRE: any; BRAND_GOLD: any; BRAND_EMBER: any; BRAND_SPARK: any;
    BRAND_BG: any; BRAND_TEXT1: any;
  }) {
    const {
      batchDeriveFast, getMaterialPalette, checkContrast,
      engineCacheSize, BRAND_FIRE, BRAND_GOLD, BRAND_EMBER, BRAND_SPARK,
      BRAND_BG, BRAND_TEXT1,
    } = api;

    const ring  = document.getElementById('color-ring');
    const table = document.getElementById('token-table');
    const cont  = document.getElementById('contrast-col');
    const cache = document.getElementById('inspector-cache');

    const SIM_NAMES  = ['IGNIS', 'AQUA', 'VELUM', 'FERRUM'] as const;
    const SIM_BASES  = [BRAND_FIRE, BRAND_GOLD, BRAND_EMBER, BRAND_SPARK];
    const SIM_KEYS   = ['ignis', 'aqua', 'velum', 'ferrum'] as const;
    const STRIP_IDS  = ['ignis-oklch','aqua-oklch','velum-oklch','ferrum-oklch'];
    const CARD_IDS   = ['card-ignis','card-aqua','card-velum','card-ferrum'];

    // Build ring swatches once
    if (ring) {
      ring.innerHTML = SIM_BASES.map((b, i) => {
        const idx = Math.min(Math.round(b.l * 255), ramp.length - 1);
        return `<div class="mat-color-swatch" id="ring-${i}" data-label="${SIM_NAMES[i]}" style="background:${ramp[idx]};"></div>`;
      }).join('');
    }

    let cycle = 0;

    async function updateInspector() {
      const activeIdx  = cycle % 4;
      const simKey     = SIM_KEYS[activeIdx];
      const base       = SIM_BASES[activeIdx];
      const heat       = simStats[simKey].heatLevel;
      cycle++;

      // ── IT2 CORE: shift base OKLCH color by live simulation heat ──────────
      // hotter simulation → higher lightness + chroma → warmer derived tokens
      const dynamicBase = {
        l: Math.min(0.94, base.l + heat * 0.18),
        c: Math.min(0.36, base.c + heat * 0.06),
        h: base.h,
      };

      // Single WASM round-trip for active sim
      const t0 = performance.now();
      const [states] = await batchDeriveFast([dynamicBase]);
      const batchMs  = (performance.now() - t0).toFixed(1);

      // Engine stats row
      const engineEl = document.getElementById('engine-stats');
      if (engineEl) {
        engineEl.innerHTML = `<span class="mat-mono">cache ${engineCacheSize()} · ${batchMs}ms · ${SIM_NAMES[activeIdx]} heat ${(heat * 100).toFixed(0)}%</span>`;
      }

      // Token table — 6 UI states derived from heat-shifted OKLCH
      if (table) {
        const stateKeys = ['idle','hover','active','focus','disabled','loading'] as const;
        table.innerHTML = stateKeys.map(k => `
          <div class="mat-token-cell">
            <div class="mat-token-swatch" style="background:${states[k]};"></div>
            <div class="mat-token-info">
              <div class="mat-token-name">${k}</div>
              <div class="mat-token-hex">${states[k]}</div>
            </div>
          </div>
        `).join('');
      }

      // WCAG contrast — live validation with dynamic color
      if (cont) {
        const pairs = [
          { label: 'Text on BG',              fg: BRAND_TEXT1,  bg: BRAND_BG },
          { label: `${SIM_NAMES[activeIdx]} heat`, fg: dynamicBase, bg: BRAND_BG },
        ];
        const rows = await Promise.all(pairs.map(async p => {
          const r   = await checkContrast(p.fg, p.bg);
          const cls = r.passesAA ? 'mat-contrast-pass' : 'mat-contrast-fail';
          const lbl = r.passesAAA ? 'AAA' : r.passesAA ? 'AA' : 'FAIL';
          return `<div class="mat-contrast-row">
            <span class="mat-contrast-pair">${p.label}</span>
            <span class="mat-contrast-ratio">${r.wcagRatio.toFixed(1)}:1</span>
            <span class="mat-contrast-badge ${cls}">${lbl}</span>
          </div>`;
        }));
        cont.innerHTML = rows.join('');
      }

      // Ring highlight — pulse active swatch
      document.querySelectorAll<HTMLElement>('.mat-color-swatch').forEach((el, i) => {
        el.style.boxShadow = i === activeIdx
          ? `0 0 0 3px ${states.idle}, 0 0 18px ${states.idle}70`
          : '';
      });

      // OKLCH strips — each driven by its own simulation heat
      await Promise.all(STRIP_IDS.map(async (id, i) => {
        const el = document.getElementById(id);
        if (!el) return;
        const h = simStats[SIM_KEYS[i]].heatLevel;
        const dynColor = {
          l: Math.min(0.94, SIM_BASES[i].l + h * 0.18),
          c: Math.min(0.36, SIM_BASES[i].c + h * 0.06),
          h: SIM_BASES[i].h,
        };
        const [tok] = await batchDeriveFast([dynColor]);
        el.style.background = `linear-gradient(90deg, ${tok.disabled}, ${tok.idle}, ${tok.hover}, ${tok.active})`;
      }));

      // IT2: Live card glow — getMaterialPalette() drives box-shadow intensity
      // Hotter sim → brighter glow color → larger glow radius
      await Promise.all(CARD_IDS.map(async (cardId, i) => {
        const h = simStats[SIM_KEYS[i]].heatLevel;
        if (h < 0.02) return; // skip effectively cold sims
        const dynColor = {
          l: Math.min(0.94, SIM_BASES[i].l + h * 0.15),
          c: SIM_BASES[i].c,
          h: SIM_BASES[i].h,
        };
        const pal = await getMaterialPalette(dynColor);
        const el  = document.getElementById(cardId) as HTMLElement | null;
        if (!el) return;
        const glowPx = Math.round(8 + h * 28);   // 8px cold → 36px hot
        el.style.setProperty('--m-glow', pal.glow);
        el.style.setProperty('--m-edge', pal.edge);
        el.style.boxShadow = [
          `0 ${glowPx}px ${glowPx * 3}px rgba(0,0,0,0.5)`,
          `0 0 ${glowPx}px ${pal.glow}40`,
          `inset 0 1px 0 ${pal.specular}30`,
        ].join(', ');
      }));

      // Cache counter
      if (cache) cache.textContent = `Cache: ${engineCacheSize()} entries`;
    }

    updateInspector();
    setInterval(updateInspector, 600);
  }

  bootMaterials().catch(e => console.error('[MaterialLab] boot failed:', e));
</script>
