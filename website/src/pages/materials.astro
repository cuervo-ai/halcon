}
.mat-token-cell {
  border-radius: 0.5rem;
  overflow: hidden;
  border: 1px solid rgba(200,80,0,0.08);
}
.mat-token-swatch { height: 36px; transition: background 0.4s ease; }
.mat-token-info { padding: 0.35rem 0.5rem; background: rgba(12,6,2,0.7); }
.mat-token-name { font-family: var(--font-mono); font-size: 0.58rem; color: var(--c-t4); }
.mat-token-hex  { font-family: var(--font-mono); font-size: 0.68rem; color: var(--c-t1); font-weight: 600; }

/* Contrast col */
.mat-contrast-col { display: flex; flex-direction: column; gap: 0.4rem; min-width: 160px; }
.mat-contrast-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  padding: 0.4rem 0.6rem;
  background: rgba(12,6,2,0.5);
