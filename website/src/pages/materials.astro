  font-size: 0.62rem;
}
.mat-prop:last-child, .mat-prop:nth-last-child(2) { border-bottom: none; }
.mat-prop span:first-child { color: var(--c-t3); }
.mat-prop span:last-child  { color: var(--c-t1); font-weight: 600; }

/* ── OKLCH color strip ───────────────────────────────────────────────────── */
.mat-oklch-strip {
  height: 6px;
  margin: 0.75rem 1rem 1.25rem;
