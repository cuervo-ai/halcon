}
.mat-note-badge--1 { background: rgba(232,82,0,0.18); color: var(--c-p);    border: 1px solid rgba(232,82,0,0.3); }
.mat-note-badge--2 { background: rgba(245,160,0,0.18); color: var(--c-gold); border: 1px solid rgba(245,160,0,0.3); }
