---
import Layout from '../layouts/Layout.astro';
import SmartDownload from '../components/download/SmartDownload';
import PlatformsTable from '../components/download/PlatformsTable';
import { t } from '../i18n/translations';

const lang = 'en';

const RELEASES_URL = "https://releases.cli.cuervo.cloud";

const installMethods = [
  {
    label: "macOS / Linux",
    color: "emerald",
    lang: "bash",
    code: "curl -sSfL https://halcon.cuervo.cloud/install.sh | sh",
    note: "SHA-256 verified. Installs to ~/.local/bin/",
  },
  {
    label: "Windows (PowerShell)",
    color: "blue",
    lang: "powershell",
    code: "iwr -useb https://halcon.cuervo.cloud/install.ps1 | iex",
    note: "Installs to %LOCALAPPDATA%\\halcon\\bin",
  },
  {
    label: "Homebrew",
    color: "amber",
    lang: "bash",
    code: "brew tap cuervo-ai/tap && brew install halcon",
    note: "macOS and Linux — auto-updates with brew upgrade",
  },
];
---

<Layout
  title={t(lang, 'meta.download.title')}
  description={t(lang, 'meta.download.desc')}
  lang={lang}
>

  <!-- Header -->
  <section class="pt-28 pb-12 px-4 text-center border-b" style="border-color: var(--c-b); background: rgba(7,4,1,0.70);">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border text-sm font-medium"
           style="border-color: rgba(232,82,0,0.35); background: rgba(232,82,0,0.08); color: var(--c-gold);">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background: var(--c-p);"></span>
        Latest release
      </div>
      <h1 class="text-5xl font-black mb-4 tracking-tight font-display">Download <span class="gradient-text-brand">Halcón CLI</span></h1>
      <p class="text-xl" style="color: var(--c-t3);">
        AI-powered coding agent for your terminal.<br class="hidden sm:block"/>
        Multi-model. Native performance.
      </p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 py-16 space-y-20">

    <!-- Smart platform detection -->
    <section>
      <SmartDownload client:load releasesUrl={RELEASES_URL} />
    </section>

    <!-- Install methods -->
    <section>
      <h2 class="text-2xl font-bold mb-8">Install methods</h2>
      <div class="space-y-3">
        {installMethods.map(m => {
          const colorMap = {
            emerald: "var(--c-emerald)",
            blue:    "var(--c-gold)",
            amber:   "var(--c-gold)",
            violet:  "var(--c-p)",
          };
          const textColor = colorMap[m.color] ?? "var(--c-p)";
          return (
            <div class="glass rounded-xl overflow-hidden transition-colors"
                 onmouseover="this.style.borderColor='var(--c-bh)'"
                 onmouseout="this.style.borderColor=''">
              <div class="flex items-center justify-between px-4 py-2.5 border-b" style="border-color: var(--c-b); background: var(--c-surface);">
                <span class="text-xs font-medium" style="color: var(--c-t2);">{m.label}</span>
                <span class="text-xs font-mono" style={`color: ${textColor};`}>{m.lang}</span>
              </div>
              <div class="flex items-center justify-between px-4 py-4 gap-4">
                <code class="font-mono text-sm flex-1 min-w-0 break-all" style={`color: ${textColor};`}>
                  {m.code}
                </code>
                <button
                  class="copy-btn flex-shrink-0 p-1.5 rounded transition-colors"
                  data-copy={m.code}
                  title="Copy"
                  style="color: var(--c-t4);"
                  onmouseover="this.style.color='var(--c-t1)'; this.style.background='var(--c-surface)'"
                  onmouseout="this.style.color='var(--c-t4)'; this.style.background='transparent'"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                  </svg>
                </button>
              </div>
              <div class="px-4 pb-3 text-xs" style="color: var(--c-t4);">{m.note}</div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- All platforms (data-driven from manifest) -->
    <section>
      <h2 class="text-2xl font-bold mb-8">All platforms</h2>
      <PlatformsTable client:load releasesUrl={RELEASES_URL} lang="en" />
    </section>

    <!-- Verify section -->
    <section>
      <h2 class="text-2xl font-bold mb-3">Verify your download</h2>
      <p class="mb-6 text-sm leading-relaxed" style="color: var(--c-t3);">
        All releases include a <code class="px-1.5 py-0.5 rounded text-xs font-mono" style="color: var(--c-t1); background: var(--c-surface);">checksums.txt</code> with SHA-256 hashes.
        The installer verifies automatically. To verify manually:
      </p>

      <div class="space-y-4">
        <!-- SHA-256 -->
        <div class="rounded-xl overflow-hidden" style="background: var(--c-code); border: 1px solid var(--c-b);">
          <div class="px-4 py-2.5 border-b text-xs" style="border-color: rgba(232,82,0,0.12); background: var(--c-surface); color: var(--c-t3);">SHA-256 checksum</div>
          <div class="p-4 font-mono text-xs space-y-1.5 leading-relaxed" style="color: var(--c-t2);">
            <div><span style="color: var(--c-t4);"># macOS</span></div>
            <div style="color: var(--c-emerald);">shasum -a 256 halcon-&lt;version&gt;-aarch64-apple-darwin.tar.gz</div>
            <div class="mt-2"><span style="color: var(--c-t4);"># Linux</span></div>
            <div style="color: var(--c-emerald);">sha256sum halcon-&lt;version&gt;-x86_64-unknown-linux-musl.tar.gz</div>
            <div class="mt-2"><span style="color: var(--c-t4);"># Compare with published hash</span></div>
            <div style="color: var(--c-emerald);">curl -sSf {RELEASES_URL}/latest/checksums.txt</div>
          </div>
        </div>

        <!-- Cosign -->
        <div class="rounded-xl overflow-hidden" style="background: var(--c-code); border: 1px solid var(--c-b);">
          <div class="px-4 py-2.5 border-b text-xs" style="border-color: rgba(232,82,0,0.12); background: var(--c-surface); color: var(--c-t3);">Cosign keyless verification (SLSA)</div>
          <div class="p-4 font-mono text-xs space-y-1 leading-relaxed" style="color: var(--c-t2);">
            <div style="color: var(--c-emerald);">cosign verify-blob \</div>
            <div class="pl-4" style="color: var(--c-emerald);">--signature halcon-&lt;version&gt;-TARGET.tar.gz.sig \</div>
            <div class="pl-4" style="color: var(--c-emerald);">--certificate halcon-&lt;version&gt;-TARGET.tar.gz.pem \</div>
            <div class="pl-4" style="color: var(--c-emerald);">--certificate-identity-regexp 'https://github.com/cuervo-ai/halcon-cli' \</div>
            <div class="pl-4" style="color: var(--c-emerald);">--certificate-oidc-issuer 'https://token.actions.githubusercontent.com' \</div>
            <div class="pl-4" style="color: var(--c-emerald);">halcon-&lt;version&gt;-TARGET.tar.gz</div>
          </div>
        </div>
      </div>
    </section>

    <!-- After install -->
    <section class="glass rounded-2xl p-8">
      <h2 class="text-xl font-bold mb-6">After installing</h2>
      <div class="space-y-4">
        {[
          { step: "1", cmd: "halcon auth login anthropic", note: "Add your Anthropic API key" },
          { step: "2", cmd: "halcon chat \"Hello, Halcón!\"", note: "Test the connection" },
          { step: "3", cmd: "halcon chat --tui", note: "Launch the full TUI cockpit" },
        ].map(s => (
          <div class="flex items-start gap-4">
            <div class="w-7 h-7 rounded-lg flex items-center justify-center text-xs font-mono shrink-0 mt-0.5"
                 style="background: var(--c-surface); color: var(--c-t3); border: 1px solid var(--c-b);">{s.step}</div>
            <div>
              <code class="font-mono text-sm" style="color: var(--c-emerald);">{s.cmd}</code>
              <div class="text-xs mt-1" style="color: var(--c-t4);">{s.note}</div>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 pt-6 border-t" style="border-color: var(--c-b);">
        <a href="/docs" class="text-sm transition-colors"
           style="color: var(--c-p);"
           onmouseover="this.style.color='var(--c-gold)'"
           onmouseout="this.style.color='var(--c-p)'">
          Read the full documentation ↗
        </a>
      </div>
    </section>

  </main>
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const icon = btn.querySelector('svg');
        if (icon) {
          icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>';
          btn.classList.add('text-emerald-400');
          setTimeout(() => {
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
            btn.classList.remove('text-emerald-400');
          }, 1500);
        }
      } catch {}
    });
  });
</script>
